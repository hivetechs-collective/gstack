# MCP Server Environment Variables
# Copy this file to .env and fill in your values

# REF Tools API Key (optional but recommended)
# Get your API key from: https://ref.tools/
# Provides 60-95% token reduction on documentation lookups
# Free tier available, paid plans start at ~$10/month
REF_API_KEY=your-ref-api-key-here

# Other potential environment variables for future MCP servers
# Uncomment and configure as needed:

# GITHUB_TOKEN=your-github-token-here
# ANTHROPIC_API_KEY=your-anthropic-key-here
# OPENAI_API_KEY=your-openai-key-here
