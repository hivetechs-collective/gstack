# Claude Code CLI Recommended Environment Variables
# Copy these to your shell profile (~/.zshrc, ~/.bashrc) or source this file
#
# Usage:
#   source /path/to/claude-pattern/.claude/env.recommended
#
# Or add individual variables to your shell profile

# ============================================================================
# CONTEXT MANAGEMENT
# ============================================================================

# Trigger auto-compaction earlier (default: 95%)
# Lower values give more time to save state before forced compaction
export CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=80

# ============================================================================
# TASK MANAGEMENT
# ============================================================================

# Use project-specific task list (tasks stored in ~/.claude/tasks/<id>/)
# Useful for isolating tasks between projects
export CLAUDE_CODE_TASK_LIST_ID=claude-pattern

# ============================================================================
# BASH TIMEOUT
# ============================================================================

# Time before long-running commands auto-background (default: 120000ms = 2min)
# Increase for builds, tests, or long operations
export BASH_DEFAULT_TIMEOUT_MS=300000  # 5 minutes

# ============================================================================
# MCP TOOL SEARCH
# ============================================================================

# Control MCP tool lazy-loading (default: auto)
# Options: auto, auto:15, true, false
# auto = enable when MCP tools exceed 10% of context
# auto:15 = enable at 15% threshold
export ENABLE_TOOL_SEARCH=auto

# ============================================================================
# OPTIONAL: API & PERFORMANCE
# ============================================================================

# MCP server startup timeout (increase if servers are slow to start)
# export MCP_TIMEOUT=30000

# Disable background tasks if causing issues
# export CLAUDE_CODE_DISABLE_BACKGROUND_TASKS=1

# ============================================================================
# VERIFICATION
# ============================================================================

# Run this to verify variables are set:
# echo "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=$CLAUDE_AUTOCOMPACT_PCT_OVERRIDE"
# echo "CLAUDE_CODE_TASK_LIST_ID=$CLAUDE_CODE_TASK_LIST_ID"
# echo "BASH_DEFAULT_TIMEOUT_MS=$BASH_DEFAULT_TIMEOUT_MS"
